{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pi.eval-row/v2",
  "type": "object",
  "required": ["schema", "task", "model", "arm", "repetition", "score", "split", "run", "fixture", "authoritative", "prompt", "serving", "usage", "status"],
  "properties": {
    "schema": {"const": "pi.eval-row/v2"},
    "task": {"type": "string"},
    "model": {"type": "string"},
    "arm": {"type": "string"},
    "repetition": {"type": "integer", "minimum": 1},
    "score": {"type": "integer", "minimum": 0, "maximum": 1},
    "split": {"enum": ["val", "heldout", "robustness"]},
    "run": {"type": "string"},
    "fixture": {"type": "object", "required": ["cohort", "version"]},
    "authoritative": {"type": "boolean"},
    "prompt": {"type": "object", "required": ["variant", "semantic_group", "sha256"]},
    "serving": {"type": "object", "required": ["pre", "post", "stable"]},
    "usage": {"type": "object", "required": ["source", "exact", "input_tokens", "output_tokens", "output_chars"]},
    "trajectory": {
      "type": "object",
      "required": ["turns", "tool_calls", "tool_errors", "reads", "unique_reads", "repeat_calls", "repeat_reads", "tool_result_chars", "first_mutation_turn", "compactions"],
      "properties": {
        "turns": {"type": "integer", "minimum": 0},
        "tool_calls": {"type": "integer", "minimum": 0},
        "tool_errors": {"type": "integer", "minimum": 0},
        "reads": {"type": "integer", "minimum": 0},
        "unique_reads": {"type": "integer", "minimum": 0},
        "repeat_calls": {"type": "integer", "minimum": 0},
        "repeat_reads": {"type": "integer", "minimum": 0},
        "tool_result_chars": {"type": "integer", "minimum": 0},
        "first_mutation_turn": {"type": "integer", "minimum": 0},
        "compactions": {"type": "integer", "minimum": 0},
        "search_spans": {"type": "integer", "minimum": 0},
        "read_span": {"type": "integer", "minimum": 0}
      }
    },
    "span_receipt_success": {"type": "boolean"},
    "config": {
      "type": "object",
      "required": ["sha256", "declared_env", "rendered_governor_sha256"],
      "properties": {
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "declared_env": {"type": "object", "additionalProperties": {"type": "string"}},
        "rendered_governor_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "experiment": {
      "type": ["object", "null"],
      "required": ["manifest_sha256", "cell"],
      "properties": {
        "manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "cell": {"type": "string", "minLength": 1}
      }
    },
    "harness": {
      "type": "object",
      "required": ["surface_sha256", "hash_blocker"],
      "properties": {
        "surface_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "hash_blocker": {"type": "string"}
      }
    },
    "context": {
      "type": "object",
      "required": ["schema", "authenticated", "content_sha256", "session_key", "events", "harness_surface_sha256", "config", "compactions", "watcher"],
      "properties": {
        "schema": {"const": "pi.context-telemetry/v1"},
        "authenticated": {"const": true},
        "content_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "session_key": {"type": "string", "minLength": 1},
        "events": {"type": "integer", "minimum": 0},
        "harness_surface_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "config": {
          "type": ["object", "null"],
          "required": ["enabled", "thresholdPct", "rearmPct"],
          "additionalProperties": false,
          "properties": {
            "enabled": {"type": "boolean"},
            "thresholdPct": {"type": "integer", "minimum": 1, "maximum": 99},
            "rearmPct": {"type": "integer", "minimum": 1, "maximum": 99}
          }
        },
        "compactions": {
          "type": "object",
          "required": ["total", "watcher", "pi", "compact_tool", "manual_unknown", "extension_content", "threshold", "overflow", "manual", "will_retry"],
          "additionalProperties": false,
          "properties": {
            "total": {"type": "integer", "minimum": 0},
            "watcher": {"type": "integer", "minimum": 0},
            "pi": {"type": "integer", "minimum": 0},
            "compact_tool": {"type": "integer", "minimum": 0},
            "manual_unknown": {"type": "integer", "minimum": 0},
            "extension_content": {"type": "integer", "minimum": 0},
            "threshold": {"type": "integer", "minimum": 0},
            "overflow": {"type": "integer", "minimum": 0},
            "manual": {"type": "integer", "minimum": 0},
            "will_retry": {"type": "integer", "minimum": 0}
          }
        },
        "watcher": {
          "type": "object",
          "required": ["requests", "completed", "failed", "thrash_silenced", "resume_required", "estimates"],
          "additionalProperties": false,
          "properties": {
            "requests": {"type": "integer", "minimum": 0},
            "completed": {"type": "integer", "minimum": 0},
            "failed": {"type": "integer", "minimum": 0},
            "thrash_silenced": {"type": "integer", "minimum": 0},
            "resume_required": {"type": "integer", "minimum": 0},
            "estimates": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["preTokens", "tokensBefore", "estimatedTokensAfter", "postTokens"],
                "additionalProperties": false,
                "properties": {
                  "preTokens": {"type": ["integer", "null"], "minimum": 0},
                  "tokensBefore": {"type": ["integer", "null"], "minimum": 0},
                  "estimatedTokensAfter": {"type": ["integer", "null"], "minimum": 0},
                  "postTokens": {"type": ["integer", "null"], "minimum": 0}
                }
              }
            }
          }
        }
      },
      "additionalProperties": false
    },
    "status": {"enum": ["complete", "incomplete", "exploratory", "ineligible"]}
  },
  "allOf": [
    {
      "if": {
        "required": ["arm"],
        "properties": {"arm": {"not": {"const": "one-shot"}}}
      },
      "then": {"required": ["trajectory"]}
    },
    {
      "if": {
        "required": ["experiment"],
        "properties": {"experiment": {"type": "object"}}
      },
      "then": {
        "required": ["span_receipt_success", "config", "experiment", "harness", "trajectory", "context"],
        "properties": {
          "trajectory": {"required": ["search_spans", "read_span"]}
        }
      }
    }
  ]
}
