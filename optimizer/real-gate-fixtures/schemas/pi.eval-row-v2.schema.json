{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pi.eval-row/v2",
  "type": "object",
  "required": ["schema", "task", "model", "arm", "repetition", "score", "split", "run", "fixture", "authoritative", "prompt", "serving", "usage", "status"],
  "properties": {
    "schema": {"const": "pi.eval-row/v2"},
    "task": {"type": "string"},
    "model": {"type": "string"},
    "arm": {"type": "string"},
    "repetition": {"type": "integer", "minimum": 1},
    "score": {"type": "integer", "minimum": 0, "maximum": 1},
    "split": {"enum": ["val", "heldout", "robustness"]},
    "run": {"type": "string"},
    "fixture": {"type": "object", "required": ["cohort", "version"]},
    "authoritative": {"type": "boolean"},
    "prompt": {"type": "object", "required": ["variant", "semantic_group", "sha256"]},
    "serving": {"type": "object", "required": ["pre", "post", "stable"]},
    "usage": {"type": "object", "required": ["source", "exact", "input_tokens", "output_tokens", "output_chars"]},
    "status": {"enum": ["complete", "incomplete", "exploratory", "ineligible"]}
  }
}
