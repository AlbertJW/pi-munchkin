{
  "defaultProvider": "local-llamacpp",
  "defaultModel": "local-model",
  "defaultThinkingLevel": "medium",
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 16000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 2,
    "baseDelayMs": 2000,
    "provider": { "timeoutMs": 1200000, "maxRetries": 0, "maxRetryDelayMs": 60000 }
  },
  "packages": [
    "vendor/pi-subagent"
  ],
  "theme": "dark"
}
